PORT=4000
NODE_ENV=production

# Public frontend origins for CORS (required in production).
# Include both www and apex; the API also auto-adds the paired domain.
CORS_ORIGIN=https://www.commiters.com,https://commiters.com

# Gmail SMTP for inquiry and job-application alerts.
# 1. Enable 2FA on commitersudaipur@gmail.com
# 2. Create a Google App Password: https://myaccount.google.com/apppasswords
# 3. Replace SMTP_PASS below (never commit the real password)
SMTP_ENABLED=true
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=commitersudaipur@gmail.com
SMTP_PASS=replace-with-gmail-app-password
SMTP_FROM=Commiters Alerts <commitersudaipur@gmail.com>

# Inquiry emails are delivered to both team inboxes:
# - hello@commiters.com
# - commitersudaipur@gmail.com
