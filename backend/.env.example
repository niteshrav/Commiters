PORT=4000
# Comma-separated list of allowed frontend origins.
# Example: http://localhost:5173,http://127.0.0.1:5173,https://www.commiters.com
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174

# Optional Supabase connection string for Prisma (not required for email-only form delivery).
DATABASE_URL=

# Email notification with PDF attachment to hello@commiters.com and commitersudaipur@gmail.com
# For production Gmail setup, copy backend/.env.production.example to DCdeploy env vars.
SMTP_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Commiters Alerts <commitersudaipur@gmail.com>

# Optional WhatsApp notification (Twilio) with PDF media link
WHATSAPP_ENABLED=false
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
WHATSAPP_NOTIFY_TO=whatsapp:+919024882899
NOTIFICATION_PUBLIC_BASE_URL=https://api.commiters.com

# MongoDB CMS
MONGODB_URI=mongodb://127.0.0.1:27017/commiters
JWT_SECRET=change-this-in-production
JWT_EXPIRES_IN=7d
ADMIN_EMAIL=admin@commiters.com
ADMIN_PASSWORD=ChangeMe123!
CMS_UPLOAD_DIR=./uploads
CMS_UPLOAD_BASE_URL=http://localhost:4000/uploads

# Technical Ledger sync with Medium
MEDIUM_RSS_URL=https://medium.com/feed/@erniteshrav
MEDIUM_RSS_CACHE_MS=300000
# Optional legacy Medium integration token (required to publish site articles to Medium)
MEDIUM_INTEGRATION_TOKEN=
# Required to publish articles from the Technical Ledger admin form
TECHNICAL_LEDGER_ADMIN_KEY=
# Optional override for local article storage path
# TECHNICAL_LEDGER_STORE_PATH=
